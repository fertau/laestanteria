rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isRegistered() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if isRegistered();
      allow update: if request.auth != null &&
        resource.data.usedBy == null;
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isRegistered();
      allow create: if request.auth != null &&
        request.auth.uid == uid;
      allow update: if isRegistered() &&
        request.auth.uid == uid;
    }

    match /follows/{id} {
      allow read: if isRegistered() &&
        (resource.data.followerUid == request.auth.uid ||
         resource.data.followingUid == request.auth.uid);
      allow create: if isRegistered();
      allow update: if isRegistered() &&
        resource.data.followingUid == request.auth.uid;
      allow delete: if isRegistered() &&
        (resource.data.followerUid == request.auth.uid ||
         resource.data.followingUid == request.auth.uid);
    }

    match /books/{bookId} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered() &&
        resource.data.uploadedBy.uid == request.auth.uid;
    }

    match /ratings/{bookId}/reviews/{uid} {
      allow read: if isRegistered();
      allow write: if isRegistered() && request.auth.uid == uid;
    }

    match /readingStatus/{uid}/books/{bookId} {
      allow read: if isRegistered();
      allow write: if isRegistered() && request.auth.uid == uid;
    }

    match /recommendations/{id} {
      allow read: if isRegistered() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
      allow create: if isRegistered();
      allow update: if isRegistered() &&
        resource.data.toUid == request.auth.uid;
    }

    match /collections/{id} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered() &&
        resource.data.createdBy.uid == request.auth.uid;
    }

    match /activity/{id} {
      allow read: if isRegistered();
      allow write: if false;
    }

    match /sendLogs/{uid}/items/{id} {
      allow read: if isRegistered() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
