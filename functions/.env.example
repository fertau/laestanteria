# Service account credentials JSON path (for Google Drive access)
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# SMTP config for sending EPUBs to Kindle
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender email for Kindle delivery
KINDLE_SENDER_EMAIL=your-email@gmail.com

# App URL for links in digest emails
APP_URL=https://your-app.vercel.app
