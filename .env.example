# URL publica de la app (para deep links de WhatsApp)
VITE_APP_URL=http://localhost:5173

# Google Custom Search Engine (image search para portadas, 100 queries/día gratis)
# VITE_GOOGLE_CSE_API_KEY=   # Opcional: usa la Firebase key si no se setea
VITE_GOOGLE_CSE_CX=
